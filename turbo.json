{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BANGERS_ADMIN_PASSWORD",
    "BANGERS_AUTH",
    "BANGERS_DEMO",
    "CLERK_SECRET_KEY",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DEFAULT_TENANT_SLUG",
    "NEON_AUTH_BASE_URL",
    "NEON_PROJECT_ID",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "PGDATABASE",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGPASSWORD",
    "PGUSER",
    "POSTGRES_DATABASE",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_URL",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_USER",
    "VITE_NEON_AUTH_URL"
  ],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "dist/**"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "lint": {}
  }
}
